{
  "name": "browseros3",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:host": "pnpm run --filter @browseros/app dev",
    "build": "pnpm run --filter=\"*\" build",
    "start": "pnpm run --parallel start",
    "prepare": "pnpm run --filter=\"@browseros/core\" --filter=\"@browseros/shared\" build"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=7.0.0"
  }
}
